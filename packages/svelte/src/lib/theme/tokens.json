{
	"$schema": "https://tr.designtokens.org/format/",
	"color": {
		"$type": "color",
		"canvas": {
			"bg": {
				"$value": "#070708",
				"$description": "Canvas background — near-true black, OLED-friendly",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-canvas-bg",
						"themes": { "light": "#f4f4f5", "highContrast": "#000000" }
					}
				}
			},
			"dot": {
				"$value": "#1e1e22",
				"$description": "Canvas grid dot color",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-canvas-dot",
						"themes": { "light": "#d4d4d8", "highContrast": "#555555" }
					}
				}
			}
		},
		"node": {
			"bg": {
				"$value": "#0e0e10",
				"$description": "Node card background — elevated surface",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-node-bg",
						"themes": { "light": "#ffffff", "highContrast": "#000000" }
					}
				}
			},
			"border": {
				"$value": "#1f1f24",
				"$description": "Node card border",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-node-border",
						"themes": { "light": "#e4e4e7", "highContrast": "#ffffff" }
					}
				}
			},
			"text": {
				"$value": "#e4e4e7",
				"$description": "Node text color",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-node-text",
						"themes": { "light": "#18181b", "highContrast": "#ffffff" }
					}
				}
			},
			"activeBorder": {
				"$value": "#00d8ff",
				"$description": "Node border when focused/active — cyan accent",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-node-active-border",
						"themes": { "light": "#007aad", "highContrast": "#00ffff" }
					}
				}
			},
			"activeGlow": {
				"$value": "rgba(0, 216, 255, 0.12)",
				"$description": "Glow shadow behind active node",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-node-active-glow",
						"themes": {
							"light": "rgba(0, 122, 173, 0.15)",
							"highContrast": "rgba(0, 255, 255, 0.3)"
						}
					}
				}
			},
			"userBorderTop": {
				"$value": "#00d8ff",
				"$description": "Top accent border for user message nodes",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-node-user-border-top",
						"themes": { "light": "#007aad", "highContrast": "#00ffff" }
					}
				}
			},
			"assistantBorderTop": {
				"$value": "#ff4400",
				"$description": "Top accent border for assistant message nodes",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-node-assistant-border-top",
						"themes": { "light": "#c93a00", "highContrast": "#ffff00" }
					}
				}
			},
			"colorRed": {
				"$value": "#ef4444",
				"$description": "Categorical node color: red",
				"$extensions": { "traek": { "cssVar": "--traek-color-red" } }
			},
			"colorOrange": {
				"$value": "#f97316",
				"$description": "Categorical node color: orange",
				"$extensions": { "traek": { "cssVar": "--traek-color-orange" } }
			},
			"colorYellow": {
				"$value": "#eab308",
				"$description": "Categorical node color: yellow",
				"$extensions": { "traek": { "cssVar": "--traek-color-yellow" } }
			},
			"colorGreen": {
				"$value": "#22c55e",
				"$description": "Categorical node color: green",
				"$extensions": { "traek": { "cssVar": "--traek-color-green" } }
			},
			"colorBlue": {
				"$value": "#3b82f6",
				"$description": "Categorical node color: blue",
				"$extensions": { "traek": { "cssVar": "--traek-color-blue" } }
			},
			"colorPurple": {
				"$value": "#a855f7",
				"$description": "Categorical node color: purple",
				"$extensions": { "traek": { "cssVar": "--traek-color-purple" } }
			},
			"colorPink": {
				"$value": "#ec4899",
				"$description": "Categorical node color: pink",
				"$extensions": { "traek": { "cssVar": "--traek-color-pink" } }
			},
			"colorCyan": {
				"$value": "#06b6d4",
				"$description": "Categorical node color: cyan",
				"$extensions": { "traek": { "cssVar": "--traek-color-cyan" } }
			}
		},
		"connection": {
			"stroke": {
				"$value": "#252528",
				"$description": "SVG line connecting parent to child nodes",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-connection-stroke",
						"themes": { "light": "#d4d4d8", "highContrast": "#ffffff" }
					}
				}
			},
			"highlight": {
				"$value": "#00d8ff",
				"$description": "Connection line highlight / active path",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-connection-highlight",
						"themes": { "light": "#007aad", "highContrast": "#00ffff" }
					}
				}
			}
		},
		"input": {
			"bg": {
				"$value": "rgba(14, 14, 16, 0.85)",
				"$description": "Composer / input bar background — frosted glass",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-input-bg",
						"themes": {
							"light": "rgba(255, 255, 255, 0.97)",
							"highContrast": "rgba(0, 0, 0, 0.95)"
						}
					}
				}
			},
			"border": {
				"$value": "#2a2a30",
				"$description": "Input bar border",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-input-border",
						"themes": { "light": "#d4d4d8", "highContrast": "#ffffff" }
					}
				}
			},
			"shadow": {
				"$value": "rgba(0, 0, 0, 0.6)",
				"$description": "Input bar drop shadow",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-input-shadow",
						"themes": { "light": "rgba(0, 0, 0, 0.08)", "highContrast": "rgba(255, 255, 255, 0.2)" }
					}
				}
			},
			"buttonBg": {
				"$value": "#00d8ff",
				"$description": "Send button background — primary accent",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-input-button-bg",
						"themes": { "light": "#007aad", "highContrast": "#00ffff" }
					}
				}
			},
			"buttonText": {
				"$value": "#000000",
				"$description": "Send button text color",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-input-button-text",
						"themes": { "light": "#ffffff", "highContrast": "#000000" }
					}
				}
			},
			"text": {
				"$value": "#f4f4f5",
				"$description": "Input text color",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-input-text",
						"themes": { "light": "#18181b", "highContrast": "#ffffff" }
					}
				}
			},
			"contextBg": {
				"$value": "rgba(0, 0, 0, 0.35)",
				"$description": "Context pill background in input area",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-input-context-bg",
						"themes": { "light": "rgba(0, 0, 0, 0.04)", "highContrast": "rgba(255, 255, 255, 0.1)" }
					}
				}
			},
			"contextText": {
				"$value": "#71717a",
				"$description": "Context pill text",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-input-context-text",
						"themes": { "light": "#52525b", "highContrast": "#ffffff" }
					}
				}
			},
			"dot": {
				"$value": "#00d8ff",
				"$description": "Active recording/typing indicator dot",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-input-dot",
						"themes": { "light": "#007aad", "highContrast": "#00ffff" }
					}
				}
			},
			"dotMuted": {
				"$value": "#3f3f46",
				"$description": "Inactive indicator dot",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-input-dot-muted",
						"themes": { "light": "#d4d4d8", "highContrast": "#ffffff" }
					}
				}
			},
			"statsText": {
				"$value": "#71717a",
				"$description": "Token count / stats text",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-stats-text",
						"themes": { "light": "#71717a", "highContrast": "#ffffff" }
					}
				}
			}
		},
		"text": {
			"nodeText": {
				"$value": "#e4e4e7",
				"$description": "Rendered markdown text in TextNode",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-textnode-text",
						"themes": { "light": "#18181b", "highContrast": "#ffffff" }
					}
				}
			},
			"nodeBg": {
				"$value": "#111113",
				"$description": "TextNode content area background",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-textnode-bg",
						"themes": { "light": "#ffffff", "highContrast": "#000000" }
					}
				}
			},
			"quoteBorder": {
				"$value": "#2a2a30",
				"$description": "Markdown blockquote left border",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-markdown-quote-border",
						"themes": { "light": "#d4d4d8", "highContrast": "#ffffff" }
					}
				}
			},
			"quoteText": {
				"$value": "#71717a",
				"$description": "Markdown blockquote text color",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-markdown-quote-text",
						"themes": { "light": "#52525b", "highContrast": "#ffffff" }
					}
				}
			},
			"hr": {
				"$value": "#1f1f24",
				"$description": "Horizontal rule color in markdown",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-markdown-hr",
						"themes": { "light": "#e4e4e7", "highContrast": "#ffffff" }
					}
				}
			},
			"scrollbarThumb": {
				"$value": "#27272a",
				"$description": "Scrollbar thumb in TextNode",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-scrollbar-thumb",
						"themes": { "light": "#d4d4d8", "highContrast": "#ffffff" }
					}
				}
			},
			"scrollbarThumbHover": {
				"$value": "#3f3f46",
				"$description": "Scrollbar thumb hover state",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-scrollbar-thumb-hover",
						"themes": { "light": "#a1a1aa", "highContrast": "#00ffff" }
					}
				}
			},
			"typingCursor": {
				"$value": "#ff4400",
				"$description": "Streaming text cursor color",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-typing-cursor",
						"themes": { "light": "#c93a00", "highContrast": "#ffff00" }
					}
				}
			},
			"searchMatchBorder": {
				"$value": "rgba(250, 204, 21, 0.45)",
				"$description": "Search hit highlight border",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-search-match-border",
						"themes": {
							"light": "rgba(202, 138, 4, 0.55)",
							"highContrast": "rgba(255, 255, 0, 0.8)"
						}
					}
				}
			}
		},
		"thought": {
			"panelBg": {
				"$value": "rgba(14, 14, 16, 0.92)",
				"$description": "Reasoning/thought panel background",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-thought-panel-bg",
						"themes": {
							"light": "rgba(255, 255, 255, 0.97)",
							"highContrast": "rgba(0, 0, 0, 0.95)"
						}
					}
				}
			},
			"panelBorder": {
				"$value": "#1f1f24",
				"$description": "Thought panel border",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-thought-panel-border",
						"themes": { "light": "#e4e4e7", "highContrast": "#ffffff" }
					}
				}
			},
			"panelBorderActive": {
				"$value": "#00d8ff",
				"$description": "Thought panel border when expanded",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-thought-panel-border-active",
						"themes": { "light": "#007aad", "highContrast": "#00ffff" }
					}
				}
			},
			"tagCyan": {
				"$value": "#00d8ff",
				"$description": "Cyan tag in thought panel",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-thought-tag-cyan",
						"themes": { "light": "#007aad", "highContrast": "#00ffff" }
					}
				}
			},
			"tagOrange": {
				"$value": "#ff4400",
				"$description": "Orange tag in thought panel",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-thought-tag-orange",
						"themes": { "light": "#c93a00", "highContrast": "#ffff00" }
					}
				}
			},
			"toggleBg": {
				"$value": "#27272a",
				"$description": "Thought panel toggle button background",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-thought-toggle-bg",
						"themes": { "light": "#e4e4e7", "highContrast": "#000000" }
					}
				}
			}
		},
		"overlay": {
			"cardBg": {
				"$value": "rgba(14, 14, 16, 0.92)",
				"$description": "Modal/overlay card background",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-overlay-card-bg",
						"themes": {
							"light": "rgba(255, 255, 255, 0.97)",
							"highContrast": "rgba(0, 0, 0, 0.95)"
						}
					}
				}
			},
			"cardBorder": {
				"$value": "rgba(255, 255, 255, 0.07)",
				"$description": "Modal/overlay card border",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-overlay-card-border",
						"themes": { "light": "rgba(0, 0, 0, 0.09)", "highContrast": "rgba(255, 255, 255, 0.3)" }
					}
				}
			},
			"text": {
				"$value": "#e4e4e7",
				"$description": "Text inside overlays",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-overlay-text",
						"themes": { "light": "#18181b", "highContrast": "#ffffff" }
					}
				}
			},
			"pillBg": {
				"$value": "#00d8ff",
				"$description": "Action pill / badge background in overlay",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-overlay-pill-bg",
						"themes": { "light": "#007aad", "highContrast": "#00ffff" }
					}
				}
			}
		},
		"sidebar": {
			"bg": {
				"$value": "#1a1a2e",
				"$description": "Sidebar panel background",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-sidebar-bg",
						"themes": { "light": "#f0f0f5", "highContrast": "#000000" }
					}
				}
			},
			"border": {
				"$value": "rgba(255, 255, 255, 0.08)",
				"$description": "Sidebar border",
				"$extensions": {
					"traek": {
						"cssVar": "--traek-sidebar-border",
						"themes": { "light": "rgba(0, 0, 0, 0.08)", "highContrast": "#ffffff" }
					}
				}
			}
		}
	},
	"spacing": {
		"$type": "dimension",
		"xs": {
			"$value": "4px",
			"$description": "Extra-small spacing unit (4px)",
			"$extensions": { "traek": { "cssVar": "--traek-space-xs" } }
		},
		"sm": {
			"$value": "8px",
			"$description": "Small spacing unit (8px)",
			"$extensions": { "traek": { "cssVar": "--traek-space-sm" } }
		},
		"md": {
			"$value": "16px",
			"$description": "Medium spacing unit (16px)",
			"$extensions": { "traek": { "cssVar": "--traek-space-md" } }
		},
		"lg": {
			"$value": "24px",
			"$description": "Large spacing unit (24px)",
			"$extensions": { "traek": { "cssVar": "--traek-space-lg" } }
		},
		"xl": {
			"$value": "32px",
			"$description": "Extra-large spacing unit (32px)",
			"$extensions": { "traek": { "cssVar": "--traek-space-xl" } }
		}
	},
	"radius": {
		"$type": "dimension",
		"sm": {
			"$value": "6px",
			"$description": "Small border radius — tags, badges",
			"$extensions": { "traek": { "cssVar": "--traek-radius-sm" } }
		},
		"md": {
			"$value": "12px",
			"$description": "Medium border radius — cards, inputs",
			"$extensions": { "traek": { "cssVar": "--traek-radius-md" } }
		},
		"lg": {
			"$value": "24px",
			"$description": "Large border radius — panels, modals",
			"$extensions": { "traek": { "cssVar": "--traek-radius-lg" } }
		}
	},
	"typography": {
		"fontFamily": {
			"sans": {
				"$value": "system-ui, -apple-system, BlinkMacSystemFont, sans-serif",
				"$type": "fontFamily",
				"$description": "Primary sans-serif font stack",
				"$extensions": { "traek": { "cssVar": "--traek-font-family" } }
			},
			"mono": {
				"$value": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace",
				"$type": "fontFamily",
				"$description": "Monospace font stack for code blocks",
				"$extensions": { "traek": { "cssVar": "--traek-font-mono" } }
			}
		},
		"fontSize": {
			"$type": "dimension",
			"xs": {
				"$value": "10px",
				"$description": "Extra-small text — captions, timestamps",
				"$extensions": { "traek": { "cssVar": "--traek-text-xs" } }
			},
			"sm": {
				"$value": "12px",
				"$description": "Small text — labels, metadata",
				"$extensions": { "traek": { "cssVar": "--traek-text-sm" } }
			},
			"base": {
				"$value": "14px",
				"$description": "Base body text size",
				"$extensions": { "traek": { "cssVar": "--traek-text-base" } }
			},
			"lg": {
				"$value": "16px",
				"$description": "Large text — subheadings",
				"$extensions": { "traek": { "cssVar": "--traek-text-lg" } }
			},
			"xl": {
				"$value": "20px",
				"$description": "Extra-large text — section headings",
				"$extensions": { "traek": { "cssVar": "--traek-text-xl" } }
			},
			"2xl": {
				"$value": "28px",
				"$description": "Display text — page titles",
				"$extensions": { "traek": { "cssVar": "--traek-text-2xl" } }
			}
		},
		"fontWeight": {
			"$type": "number",
			"normal": {
				"$value": 400,
				"$description": "Regular weight",
				"$extensions": { "traek": { "cssVar": "--traek-weight-normal" } }
			},
			"medium": {
				"$value": 500,
				"$description": "Medium weight — UI labels",
				"$extensions": { "traek": { "cssVar": "--traek-weight-medium" } }
			},
			"semibold": {
				"$value": 600,
				"$description": "Semibold weight — headings",
				"$extensions": { "traek": { "cssVar": "--traek-weight-semibold" } }
			},
			"bold": {
				"$value": 700,
				"$description": "Bold weight — emphasis",
				"$extensions": { "traek": { "cssVar": "--traek-weight-bold" } }
			}
		}
	},
	"animation": {
		"duration": {
			"$type": "duration",
			"fast": {
				"$value": "120ms",
				"$description": "Fast transitions — hover states, micro-interactions",
				"$extensions": { "traek": { "cssVar": "--traek-duration-fast" } }
			},
			"normal": {
				"$value": "220ms",
				"$description": "Normal transitions — panel open/close",
				"$extensions": { "traek": { "cssVar": "--traek-duration-normal" } }
			},
			"slow": {
				"$value": "380ms",
				"$description": "Slow transitions — canvas pan/zoom",
				"$extensions": { "traek": { "cssVar": "--traek-duration-slow" } }
			}
		}
	}
}
