{
	"name": "@traek/whitelabel",
	"version": "0.1.0",
	"description": "White-label theming kit for @traek/svelte — brand customization, token overrides, and loading screen templates",
	"license": "SEE LICENSE IN LICENSE",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc && svelte-package",
		"check": "svelte-check --tsconfig ./tsconfig.json"
	},
	"peerDependencies": {
		"@traek/svelte": ">=0.0.4",
		"svelte": ">=5.0.0"
	},
	"devDependencies": {
		"@sveltejs/package": "^2.0.0",
		"@traek/svelte": "workspace:*",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"typescript": "^5.0.0"
	},
	"dependencies": {
		"zod": "^3.22.0"
	},
	"keywords": [
		"traek",
		"svelte",
		"white-label",
		"theming",
		"design-system",
		"enterprise"
	]
